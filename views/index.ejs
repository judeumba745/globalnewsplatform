<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Global News Platform</title>

  <style>
    body {
      font-family: Arial;
      margin: 0;
      background: #f2f2f2;
    }

    header {
      background: #111;
      color: white;
      padding: 15px;
      text-align: center;
      font-size: 20px;
    }

    .container {
      max-width: 800px;
      margin: auto;
      padding: 20px;
    }

    .card {
      background: white;
      padding: 15px;
      margin-bottom: 15px;
      border-radius: 10px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .title {
      font-size: 18px;
      font-weight: bold;
    }

    .source {
      font-size: 12px;
      color: gray;
    }

    .content {
      margin-top: 10px;
    }

    a {
      display: inline-block;
      margin-top: 10px;
      color: blue;
      text-decoration: none;
    }
  </style>
</head>

<body>

<header>
  🌍 Global News Live Platform
</header>

<div class="container">

  <% news.forEach(n => { %>

    <div class="card">
      <div class="title"><%= n.title %></div>
      <div class="source">Source: <%= n.source %> | <%= n.date %></div>
      <div class="content"><%= n.content %></div>
      <a href="<%= n.link %>" target="_blank">Lire plus</a>
    </div>

  <% }) %>

</div>

</body>
</html>