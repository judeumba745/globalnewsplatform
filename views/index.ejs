<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Global News Live</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: Arial; background: #f5f5f5; margin: 0; }
    header { background: #1a1a1a; color: white; padding: 15px; text-align: center; }
   .container { max-width: 800px; margin: 20px auto; padding: 0 10px; }
   .card { background: white; border-radius: 8px; padding: 15px; margin-bottom: 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
   .card img { width: 100%; border-radius: 5px; margin: 10px 0; }
   .card iframe { width: 100%; height: 400px; border: none; border-radius: 5px; margin: 10px 0; }
   .card h3 { margin: 10px 0; }
   .meta { color: #666; font-size: 12px; margin-bottom: 10px; }
   .actions { display: flex; gap: 10px; margin-top: 10px; }
   .btn { padding: 8px 15px; border: none; border-radius: 5px; cursor: pointer; background: #e0e0e0; }
   .btn:hover { background: #d0d0d0; }
   .comments { margin-top: 15px; padding-top: 15px; border-top: 1px solid #ddd; }
   .comment { background: #f9f9f9; padding: 8px; border-radius: 5px; margin: 5px 0; font-size: 14px; }
   .comment-input { display: flex; gap: 5px; margin-top: 10px; }
   .comment-input input { flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 5px; }
  </style>
</head>
<body>
  <header>
    <h1>🌍 Global News Live</h1>
  </header>
  <div class="container">
    <% news.forEach(item => { %>
      <div class="card">
        <div class="meta"><%= item.source %> - <%= new Date(item.date).toLocaleString('fr-FR') %></div>
        <h3><a href="<%= item.link %>" target="_blank"><%= item.title %></a></h3>

        <% if (item.video) { %>
          <iframe src="<%= item.video %>" allowfullscreen></iframe>
        <% } else if (item.image) { %>
          <img src="<%= item.image %>" alt="<%= item.title %>">
        <% } %>

        <p><%= item.summary %></p>

        <div class="actions">
          <button class="btn" onclick="like('<%= item.id %>')">👍 Like (<span id="likes-<%= item.id %>"><%= likes[item.id] || 0 %></span>)</button>
          <button class="btn" onclick="toggleComments('<%= item.id %>')">💬 Commentaires</button>
        </div>

        <div class="comments" id="comments-<%= item.id %>" style="display:none;">
          <% (comments[item.id] || []).forEach(c => { %>
            <div class="comment"><%= c.text %></div>
          <% }) %>
          <div class="comment-input">
            <input type="text" id="input-<%= item.id %>" placeholder="Écris un commentaire...">
            <button class="btn" onclick="comment('<%= item.id %>')">Envoyer</button>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <script>
    async function like(id) {
      const res = await fetch('/like', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({id})
      });
      const data = await res.json();
      document.getElementById('likes-'+id).textContent = data.likes;
    }

    async function comment(id) {
      const input = document.getElementById('input-'+id);
      const text = input.value.trim();
      if (!text) return;

      const res = await fetch('/comment', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({id, text})
      });
      location.reload();
    }

    function toggleComments(id) {
      const div = document.getElementById('comments-'+id);
      div.style.display = div.style.display === 'none'? 'block' : 'none';
    }
  </script>
</body>
</html>
