<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Global News Live Platform</title>

<style>
  body {
    font-family: Arial;
    margin: 0;
    background: #f2f2f2;
  }

  /* ✅ HEADER FIXE */
  header {
    background: #111;
    color: white;
    padding: 15px;
    text-align: center;
    font-size: 20px;

    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
  }

  .container {
    max-width: 850px;
    margin: auto;

    /* ✅ IMPORTANT : espace pour le header fixe */
    padding: 90px 20px 20px;
  }

  .card {
    background: white;
    padding: 0;
    margin-bottom: 25px;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    overflow: hidden;
  }

  .card-body {
    padding: 15px;
  }

  .title {
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 8px;
  }

  .source {
    font-size: 12px;
    color: #666;
    margin-bottom: 12px;
  }

  .card img {
    width: 100%;
    max-height: 450px;
    object-fit: cover;
  }

  .content {
    line-height: 1.7;
    color: #333;
    font-size: 15px;
    margin-bottom: 15px;
  }

  .content img {
    display: none;
  }

  iframe, video {
    width: 100%;
    height: 450px;
    border: none;
    margin-bottom: 15px;
  }

  .likes-count {
    padding: 0 15px 8px;
    font-size: 13px;
    color: #65676b;
  }

  .actions {
    display: flex;
    border-top: 1px solid #e4e6eb;
    padding-top: 8px;
  }

  .btn {
    flex: 1;
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
    font-size: 14px;
    color: #65676b;
    border-radius: 5px;
  }

  .btn:hover {
    background: #f2f3f5;
  }

  .btn.liked {
    color: #1877f2;
    font-weight: bold;
  }

  .comments-box {
    padding: 0 15px 15px;
  }

  .comment {
    background: #f2f3f5;
    padding: 8px 12px;
    border-radius: 18px;
    margin-top: 8px;
    font-size: 14px;
  }

  .comment-input {
    display: flex;
    gap: 8px;
    margin-top: 10px;
  }

  .comment-input input {
    flex: 1;
    border: none;
    background: #f2f3f5;
    padding: 8px 12px;
    border-radius: 18px;
    outline: none;
  }
</style>
</head>

<body>

<header>🌍 Global News Live Platform</header>

<div class="container">
  <% news.forEach(n => { %>
    <div class="card" data-id="<%= n.id %>">

      <% if(n.mediaType === 'video' && n.mediaUrl) { %>
        <% if(n.mediaUrl.includes('youtube') || n.mediaUrl.includes('youtu.be')) { %>
          <iframe src="<%= n.mediaUrl.replace('watch?v=', 'embed/').replace('youtu.be/', 'youtube.com/embed/') %>" allowfullscreen></iframe>
        <% } else if(n.mediaUrl.includes('dailymotion')) { %>
          <iframe src="<%= n.mediaUrl.replace('video/', 'embed/video/') %>" allowfullscreen></iframe>
        <% } else { %>
          <video controls preload="metadata">
            <source src="<%= n.mediaUrl %>" type="video/mp4">
          </video>
        <% } %>
      <% } else if(n.mediaType === 'image' && n.mediaUrl) { %>
        <img src="<%= n.mediaUrl %>" alt="<%= n.title %>">
      <% } %>

      <div class="card-body">
        <div class="title"><%= n.title %></div>
        <div class="source">Source: <%= n.source %> | <%= new Date(n.date).toLocaleString('fr-FR') %></div>
        <div class="content"><%- n.content %></div>

        <div class="likes-count">
          👍 <span class="like-count"><%= n.likes %></span> J'aime
          <span style="float:right"><span class="comment-count"><%= n.comments %></span> commentaires</span>
        </div>

        <div class="actions">
          <button class="btn like-btn" onclick="like('<%= n.id %>', this)">👍 J'aime</button>
          <button class="btn" onclick="toggleComment('<%= n.id %>')">💬 Commenter</button>
          <button class="btn" onclick="share('<%= n.link %>')">↗️ Partager</button>
        </div>

        <div class="comments-box" id="comments-<%= n.id %>" style="display:none">
          <div class="comments-list"></div>
          <div class="comment-input">
            <input type="text" placeholder="Écris un commentaire..." id="input-<%= n.id %>">
            <button onclick="comment('<%= n.id %>')">Envoyer</button>
          </div>
        </div>

      </div>
    </div>
  <% }) %>
</div>

<script>
async function like(id, btn) {
  const res = await fetch('/like', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({id})
  });

  const data = await res.json();

  const card = document.querySelector(`[data-id="${id}"]`);
  card.querySelector('.like-count').textContent = data.likes;
}

// 💬 ouvrir commentaires + charger tout
function toggleComment(id) {
  const box = document.getElementById('comments-'+id);
  const isOpen = box.style.display === 'block';

  box.style.display = isOpen ? 'none' : 'block';

  if (!isOpen) {
    loadComments(id);
  }
}

// 💬 envoyer commentaire
async function comment(id) {
  const input = document.getElementById('input-'+id);
  const text = input.value.trim();
  if (!text) return;

  await fetch('/comment', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({id, text})
  });

  input.value = '';

  loadComments(id);
}

// 🔥 SYNC GLOBAL (likes + comments)
async function loadComments(id) {
  const res = await fetch('/reactions/' + id);
  const data = await res.json();

  const card = document.querySelector(`[data-id="${id}"]`);
  const list = card.querySelector('.comments-list');

  list.innerHTML = '';

  data.comments.forEach(c => {
    const div = document.createElement('div');
    div.className = 'comment';
    div.textContent = c.text;
    list.appendChild(div);
  });

  card.querySelector('.comment-count').textContent = data.comments.length;
  card.querySelector('.like-count').textContent = data.likes;
}

// 🔗 partager
function share(link) {
  if (navigator.share) {
    navigator.share({title: 'News', url: link});
  } else {
    navigator.clipboard.writeText(link);
    alert('Lien copié!');
  }
}
</script>

</body>
</html>
