<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Global News</title>
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0d0d0d">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black">
  <link rel="apple-touch-icon" href="/icon.png">
  <style>
    body {font-family: Arial; margin: 0; background: #f2f2f2; padding-top: 130px; top: 0!important; pointer-events: auto!important;}
    header {position: fixed; top: 0; left: 0; width: 100%; height: 70px; background: linear-gradient(90deg, #0066ff, #0099ff); display: flex; justify-content: center; align-items: center; z-index: 9999; box-shadow: 0 2px 10px rgba(0,0,0,.25);}
    .header-title {color: white; font-size: 30px; font-weight: 900; font-style: italic; letter-spacing: 2px;}
    .menu-btn {position: absolute; right: 15px; color: red; font-size: 34px; cursor: pointer;}
    .menu {display: none; position: absolute; top: 70px; right: 10px; width: 220px; background: white; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,.2); padding: 15px;}
    .menu select {width: 100%; padding: 10px; margin-bottom: 10px;}
    .menu a {text-decoration: none; color: #0066ff; font-weight: bold;}
    .container {padding: 10px; max-width: 700px; margin: auto;}
    .card {background: white; margin-bottom: 12px; border-radius: 14px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08);}
    .title {background: #0b6cff; color: white; padding: 12px; font-size: 20px; font-weight: bold;}
    .news-date {padding: 10px; color: #666; font-size: 13px;}
    .content {padding: 12px; font-size: 15px; line-height: 1.6; color: #333;}
    img, video, iframe {width: 100%; display: block;}
    img {animation: zoom 6s infinite alternate;}
    @keyframes zoom {from {transform: scale(1);} to {transform: scale(1.05);}}
    .react-info {padding: 8px 12px; font-size: 13px; color: #65676b; border-bottom: 1px solid #e4e6eb;}
    .actions {display: flex; justify-content: space-around; padding: 6px 0;}
    .actions button {background: none; border: none; font-size: 15px; font-weight: 600; color: #65676b; padding: 8px 20px; border-radius: 6px; cursor: pointer; flex: 1;}
    .actions button:hover {background: #f2f3f5;}
    .actions button.active {color: #1877f2;}
    .comment-box {background: #f7f7f7; padding: 10px; border-top: 1px solid #ddd; display: none; transition: all 0.3s ease;}
    .comment-box input {width: 100%; padding: 8px; margin-bottom: 5px; border-radius: 18px; border: 1px solid #ccc; font-size: 14px; box-sizing: border-box;}
    .comment-box textarea {width: 100%; height: 50px; padding: 8px; border-radius: 18px; border: 1px solid #ccc; resize: none; font-size: 14px; box-sizing: border-box;}
    .comment-box button {margin-top: 5px; background: #1877f2; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;}
    .comment {background: #f2f3f5; padding: 8px 12px; border-radius: 18px; margin: 5px 0; font-size: 14px; animation: fadeIn 0.2s ease;}
    .comment b {display: block; font-size: 13px; color: #1877f2; margin-bottom: 3px;}
    #google_translate_element {position: fixed; bottom: 10px; right: 10px; opacity: 0.01;}
    .goog-te-banner-frame, .skiptranslate {display: none!important;}
    @keyframes fadeIn {from {opacity: 0; transform: translateY(5px);} to {opacity: 1; transform: translateY(0);}}
  </style>
</head>
<body>
  <header>
    <div class="header-title notranslate">NEWS LIVE</div>
    <div class="menu-btn" onclick="toggleMenu()">☰</div>
    <div id="menu" class="menu">
      <select id="languageSelect" onchange="changeLanguage(); closeMenu();">
        <option value="fr">🇫🇷 Français</option>
        <option value="en">🇬🇧 English</option>
        <option value="es">🇪🇸 Español</option>
        <option value="pt">🇵🇹 Português</option>
      </select>
      <a href="mailto:judeumba745@gmail.com?subject=Publicité NEWS LIVE">📢 Publicité</a>
    </div>
  </header>

  <div class="container">
    <% news.forEach(n => { %>
      <div class="card" data-id="<%= n.id %>">
        <% if(n.mediaType === 'video') { %>
          <iframe src="<%= n.mediaUrl %>?autoplay=1&mute=1" allow="autoplay; encrypted-media" allowfullscreen></iframe>
        <% } else if(n.mediaUrl) { %>
          <img src="<%= n.mediaUrl %>">
        <% } %>
        <div class="title"><%= n.title %></div>
        <div class="news-date">🕒 <%= new Date(n.date).toLocaleString("fr-FR") %></div>
        <div class="content"><%- n.content %></div>
        
        <div class="react-info"> 
          👍 <span id="like-count-<%= n.id %>"><%= n.likes %></span> <span id="like-text-<%= n.id %>">personne<%= n.likes > 1 ? 's' : '' %></span> · 
          💬 <span id="count-<%= n.id %>">0</span> <span id="comment-text-<%= n.id %>">commentaires</span> 
        </div>
        
        <div class="actions">
          <button id="like-btn-<%= n.id %>" onclick="like('<%= n.id %>', this)">👍 J’aime</button>
          <button onclick="toggleComment('<%= n.id %>')">💬 Commenter</button>
          <button onclick="share('<%= n.link %>')">↗️ Partager</button>
        </div>

        <div class="comment-box" id="comment-<%= n.id %>">
          <div id="list-<%= n.id %>" style="max-height: 300px; overflow-y: auto;"></div>
          <input type="text" placeholder="Ton nom" id="name-<%= n.id %>">
          <textarea placeholder="Écrire un commentaire..." id="text-<%= n.id %>"></textarea>
          <button onclick="sendComment('<%= n.id %>')">Envoyer</button>
        </div>
      </div>
    <% }) %>
  </div>

  <div id="google_translate_element"></div>
  <script>
    function googleTranslateElementInit() {
      new google.translate.TranslateElement({pageLanguage: 'fr', includedLanguages: 'fr,en,es,pt'}, 'google_translate_element');
    }
    function changeLanguage() {
      const lang = document.getElementById("languageSelect").value;
      localStorage.setItem("lang", lang);
      function apply() {
        const combo = document.querySelector(".goog-te-combo");
        if (combo) {combo.value = lang; combo.dispatchEvent(new Event("change"));} 
        else {setTimeout(apply, 500);}
      }
      apply();
    }
    window.onload = () => {
      const lang = localStorage.getItem("lang") || "fr";
      document.getElementById("languageSelect").value = lang;
      setTimeout(changeLanguage, 1000);
      // Charger les commentaires de chaque post direct
      <% news.forEach(n => { %>
        loadComments('<%= n.id %>');
      <% }) %>
    };
  </script>
  <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
  
  <script>
  async function like(id, btn) {
    const res = await fetch("/like", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({id})
    });
    const data = await res.json();
    
    document.getElementById("like-count-" + id).innerText = data.likes;
    document.getElementById("like-text-" + id).innerText = data.likes > 1 ? "personnes" : "personne";
    btn.classList.add("active");
  }

  function toggleComment(id) {
    const box = document.getElementById("comment-" + id);
    box.style.display = box.style.display === "block" ? "none" : "block";
    if(box.style.display === "block") loadComments(id);
  }

  async function sendComment(id) {
    const name = document.getElementById("name-" + id).value.trim();
    const text = document.getElementById("text-" + id).value.trim();
    if(!name || !text) return alert("Mets ton nom et ton commentaire");

    await fetch("/comment", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({id, text: name + ": " + text})
    });

    document.getElementById("text-" + id).value = "";
    document.getElementById("name-" + id).value = "";
    
    // Recharge commentaires mais garde la box ouverte
    await loadComments(id);
    
    // Scroll auto vers le bas pour voir son commentaire
    const list = document.getElementById("list-" + id);
    list.scrollTop = list.scrollHeight;
  }

  async function loadComments(id) {
    const res = await fetch("/reactions/" + id);
    const data = await res.json();
    
    // Update compteur
    document.getElementById("count-" + id).innerText = data.comments.length;
    document.getElementById("comment-text-" + id).innerText = data.comments.length > 1 ? "commentaires" : "commentaire";
    
    // Affiche commentaires
    const list = document.getElementById("list-" + id);
    list.innerHTML = data.comments.map(c => {
      const parts = c.text.split(": ");
      if(parts.length > 1) {
        return `<div class="comment"><b>${parts[0]}</b>${parts.slice(1).join(": ")}</div>`;
      }
      return `<div class="comment">${c.text}</div>`;
    }).join("");
  }

  function share(link) {
    if (navigator.share) {navigator.share({url: link});} 
    else {navigator.clipboard.writeText(link); alert("Lien copié!");}
  }

  function toggleMenu() {
    const menu = document.getElementById("menu");
    menu.style.display = menu.style.display === "block" ? "none" : "block";
  }
  function closeMenu() {document.getElementById("menu").style.display = "none";}
  </script>

  <script>
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", () => {
        navigator.serviceWorker.register("/sw.js").then(() => console.log("PWA activée 🚀")).catch(err => console.log("Erreur PWA", err));
      });
    }
  </script>
</body>
</html>
